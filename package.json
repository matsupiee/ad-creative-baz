{
  "name": "ad-creative-baz",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.90.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @ad-creative-baz/db db:push",
    "db:generate": "turbo -F @ad-creative-baz/db db:generate",
    "deploy": "turbo -F @ad-creative-baz/infra deploy",
    "destroy": "turbo -F @ad-creative-baz/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@ad-creative-baz/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ad-creative-baz/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/node": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
